{
  "name": "generative-nft-art",
  "version": "1.0.0",
  "description": "Algorithmic generative art creation toolkit for NFT deployment",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js,.ts",
    "lint:fix": "eslint src/ --ext .js,.ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "type-check": "tsc --noEmit",
    "generate": "node scripts/generate-art.js",
    "preview": "node scripts/preview-generator.js",
    "deploy": "node scripts/deploy.js",
    "docs": "typedoc src/",
    "clean": "rimraf dist output coverage docs"
  },
  "keywords": [
    "generative-art",
    "nft",
    "algorithmic-art",
    "canvas",
    "creative-coding",
    "highlight-xyz"
  ],
  "author": "Joshua Nibert",
  "license": "MIT",
  "dependencies": {
    "canvas": "^2.11.2",
    "seedrandom": "^3.0.5",
    "simplex-noise": "^4.0.1",
    "chroma-js": "^2.4.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.14.199",
    "@types/seedrandom": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4",
    "typedoc": "^0.25.1",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["jest-canvas-mock"],
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/**/*.d.ts",
      "!src/examples/**"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "testMatch": [
      "<rootDir>/tests/**/*.(test|spec).(js|ts)",
      "<rootDir>/src/**/__tests__/**/*.(test|spec).(js|ts)"
    ]
  }
}